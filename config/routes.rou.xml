<?xml version="1.0" encoding="UTF-8"?>
<routes xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://sumo.dlr.de/xsd/routes_file.xsd">
    
    <!-- Vehicle Type Definitions -->
    <vType id="car" 
           accel="2.6" 
           decel="4.5" 
           sigma="0.5" 
           length="5.0" 
           maxSpeed="13.89"/>
    
    <vType id="emergency_vehicle" 
           accel="3.5" 
           decel="5.0" 
           sigma="0.3" 
           length="6.0" 
           maxSpeed="20.0" 
           color="255,0,0"/>
    
    <!-- Route Definitions -->
    <route id="route_1" edges="I1_to_I2 I2_to_I4 I4_to_I3"/>
    <route id="route_2" edges="I2_to_I1 I1_to_I3 I3_to_I4"/>
    <route id="route_3" edges="I3_to_I4 I4_to_I2 I2_to_I1"/>
    <route id="route_4" edges="I4_to_I3 I3_to_I1 I1_to_I2"/>
    
    <!-- Traffic Flow Definitions -->
    <flow id="flow_1" 
          route="route_1" 
          begin="0" 
          end="3600" 
          period="30" 
          type="car"/>
    
    <flow id="flow_2" 
          route="route_2" 
          begin="0" 
          end="3600" 
          period="35" 
          type="car"/>
    
    <flow id="flow_3" 
          route="route_3" 
          begin="0" 
          end="3600" 
          period="40" 
          type="car"/>
    
    <flow id="flow_4" 
          route="route_4" 
          begin="0" 
          end="3600" 
          period="45" 
          type="car"/>
    
</routes>
